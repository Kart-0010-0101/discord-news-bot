# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
# Comma-separated channel IDs (add more to post to multiple servers/channels)
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2

# Finnhub (free — https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Currents API (free — https://currentsapi.services/register)
CURRENTS_API_KEY=your_currents_api_key_here

# Optional: WorldMonitor (if you have a key)
# WORLDMONITOR_API_KEY=your_worldmonitor_key_here
